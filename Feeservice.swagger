{"openapi":"3.0.1","info":{"title":"Fee Service API","description":"APIs for Fee collection and receipts","version":"1.0"},"servers":[{"url":"http://localhost:8082","description":"Generated server url"}],"tags":[{"name":"Fee API","description":"Operations related to fee Collection"},{"name":"Receipts API","description":"Operations related to Receipts"}],"paths":{"/fee":{"post":{"tags":["Fee API"],"summary":"Collect fee","operationId":"collectFee","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CollectFeeRequest"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/Receipt"}}}}}}},"/receipts":{"get":{"tags":["Receipts API"],"summary":"Get All Students Receipts","operationId":"getAllReceipts","responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/Receipt"}}}}}}}},"/receipts/{id}":{"get":{"tags":["Receipts API"],"summary":"Get Receipt by id","operationId":"getReceiptById","parameters":[{"name":"id","in":"path","required":true,"schema":{"type":"integer","format":"int64"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/Receipt"}}}}}}},"/receipts/{id}/pdf":{"get":{"tags":["Receipts API"],"summary":"Download Reciept in PDF","operationId":"downloadReceiptPdf","parameters":[{"name":"id","in":"path","required":true,"schema":{"type":"integer","format":"int64"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"string","format":"byte"}}}}}}},"/receipts/student/{studentId}":{"get":{"tags":["Receipts API"],"summary":"Get Receipt by Student id","operationId":"getReceiptsByStudentId","parameters":[{"name":"studentId","in":"path","required":true,"schema":{"type":"integer","format":"int64"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/Receipt"}}}}}}}}},"components":{"sche